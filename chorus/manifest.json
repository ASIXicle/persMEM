{
  "manifest_version": 2,
  "name": "Chorus",
  "version": "0.4.0",
  "description": "Three-instance Claude prompt relay — round-robin with dynamic agent names",
  "permissions": [
    "tabs",
    "storage",
    "activeTab"
  ],
  "content_scripts": [
    {
      "matches": ["*://claude.ai/*"],
      "js": ["selectors.js", "content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "sidebar_action": {
    "default_title": "Chorus",
    "default_panel": "sidebar.html",
    "default_icon": "icon.svg"
  },
  "icons": {
    "48": "icon.svg"
  }
}
