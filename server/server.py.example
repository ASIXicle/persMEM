    print(f"[persMEM] Starting MCP server on {HOST}:{PORT}")
    print(f"[persMEM] Mount path: /{SECRET_PATH}/mcp")
    mcp.run(
        transport="streamable-http",
        mount_path=f"/{SECRET_PATH}/mcp",
    )
