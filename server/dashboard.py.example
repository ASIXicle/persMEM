  .compose-row select, .compose-row input {
    padding: 6px 10px; border: 1px solid var(--border); border-radius: 4px;
    font-size: 12px; background: var(--bg); color: var(--text);
  }
  .compose-row select { min-width: 90px; }
  .compose-row input { flex: 1; min-width: 150px; }
  .compose-body {
    width: 100%; margin-top: 8px; padding: 8px; border: 1px solid var(--border);
    border-radius: 4px; font-size: 12px; font-family: inherit; resize: vertical;
    min-height: 80px; background: var(--bg); color: var(--text);
  }
  .compose-send {
    margin-top: 8px; padding: 6px 16px; background: #2d7dd2; color: white;
    border: none; border-radius: 4px; font-size: 12px; cursor: pointer; font-weight: 600;
  }
  .compose-send:hover { background: #2569b0; }
  .compose-send:disabled { opacity: 0.5; cursor: not-allowed; }
  .compose-feedback { font-size: 11px; margin-top: 6px; }

  /* Export buttons */
  .export-row { display: flex; gap: 8px; margin-bottom: 16px; }
  .export-btn {
    padding: 5px 14px; background: var(--surface); border: 1px solid var(--border);
    border-radius: 6px; font-size: 12px; color: var(--text-dim); cursor: pointer;
    text-decoration: none; font-weight: 600;
  }
  .export-btn:hover { border-color: var(--accent); color: var(--accent); }

  /* ECG sweep animation — faint hospital monitor style */
  .ecg-sweep {
    position: absolute; top: 0; left: -20%; width: 20%; height: 100%;
    background: linear-gradient(90deg, transparent 0%, rgba(46,164,67,0.04) 40%, rgba(46,164,67,0.09) 50%, rgba(46,164,67,0.04) 60%, transparent 100%);
    animation: ecg-scan 6s linear infinite;
    pointer-events: none;
  }
  @keyframes ecg-scan {
    0% { left: -20%; }
    100% { left: 100%; }
  }

  @media (max-width: 768px) {
    body { padding: 12px; }
    .stats-row { grid-template-columns: repeat(2, 1fr); }
    .charts-row { grid-template-columns: 1fr; }
  }
</style>
</head>
<body>

<h1>persMEM</h1>

<!-- Mission Control -->
<div class="panel" style="padding:16px 20px; margin-bottom:20px;">
  <div style="display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:8px; margin-bottom:12px;">
    <div style="display:flex; gap:14px; align-items:center; flex-wrap:wrap;">
      <div class="status-item"><span class="status-dot green" id="dotPersmem"></span> <strong>persMEM</strong></div>
      <div class="status-item"><span class="status-dot green"></span> Dashboard</div>
    </div>
    <div style="display:flex; gap:16px; align-items:center; flex-wrap:wrap; font-size:12px; color:var(--text-dim);">
      <span id="statusModel" style="font-weight:600; color:var(--accent);">voyage-4-nano</span>
      <span id="statusUptime">Uptime: --</span>
    </div>
  </div>
  <div style="display:flex; gap:12px; flex-wrap:wrap; margin-bottom:14px;">
    <span class="badge badge-project" style="font-size:12px; padding:4px 12px;">{{ total_memories }} memories</span>
    <span class="badge badge-type" style="font-size:12px; padding:4px 12px;">{{ total_news }} news</span>
    <span class="badge" style="font-size:12px; padding:4px 12px; background:rgba(45,125,210,0.12); color:var(--kite-color);">{{ total_amq }} AMQ</span>
    <span class="badge" style="font-size:12px; padding:4px 12px; background:rgba(212,146,11,0.12); color:var(--knot-color);">{{ projects | length }} projects</span>
    <span class="badge badge-tag" style="font-size:12px; padding:4px 12px;">{{ agents | length }} agents</span>
  </div>
  <div style="height:60px; position:relative; overflow:hidden;">
    <canvas id="sparkline"></canvas>
    <div class="ecg-sweep"></div>
  </div>
  <div style="display:flex; gap:12px; justify-content:center; margin-top:6px; font-size:10px; color:var(--text-dim);">
    <span style="color:#9b59b6;">&#9679; memories</span>
    <span style="color:#2d7dd2;">&#9679; AMQ</span>
    <span style="color:#27ae60;">&#9679; news</span>
    <span style="color:rgba(46,164,67,0.35);">&#9644; heartbeat</span>
  </div>
</div>

<!-- AMQ Live Feed -->
<div class="panel">
  <div class="panel-header">
    <h3><span class="amq-live-dot"></span> AMQ Live Feed</h3>
    <span class="amq-status" id="amqStatus">Loading...</span>
  </div>
  <div class="amq-count-row" id="amqCounts"></div>
  <div class="amq-feed" id="amqFeed"><div class="amq-empty">Loading...</div></div>
  <!-- AMQ Compose Box -->
  <div class="compose-box">
    <details>
      <summary>Compose AMQ Message</summary>
      <div class="compose-row">
        <select id="composeFrom"><option value="holden">holden</option></select>
        <span style="color:var(--text-dim);font-size:12px;line-height:30px;">&rarr;</span>
        <select id="composeTo">
          {% for a in agents %}<option value="{{ a }}">{{ a }}</option>{% endfor %}
        </select>
        <input type="text" id="composeSubject" placeholder="Subject...">
      </div>
      <textarea class="compose-body" id="composeBody" placeholder="Message body (Markdown)..."></textarea>
      <button class="compose-send" id="composeSend" onclick="sendAmq()">Send</button>
      <div class="compose-feedback" id="composeFeedback"></div>
    </details>
  </div>
</div>

<!-- Stacked Activity Timeline -->
<div class="timeline-card">
  <h3>Triad Activity (Memories + AMQ + News per day)</h3>
  <div style="max-height:220px;"><canvas id="activityChart"></canvas></div>
</div>

<!-- Charts Row -->
<div class="charts-row">
  <div class="chart-card"><h3>By Project</h3><div class="chart-wrap"><canvas id="projectChart"></canvas></div></div>
  <div class="chart-card"><h3>By Type</h3><div class="chart-wrap"><canvas id="typeChart"></canvas></div></div>
  <div class="chart-card"><h3>By Top Tags</h3><div class="chart-wrap"><canvas id="tagChart"></canvas></div></div>
</div>

<!-- Collection Tabs + Browser -->
<h2 class="section-title">Index</h2>
<div class="tab-row">
  <button class="tab-btn active" onclick="switchTab('memories')">Memories ({{ total_memories }})</button>
  <button class="tab-btn" onclick="switchTab('news')">News ({{ total_news }})</button>
</div>
<div class="export-row">
  <a class="export-btn" href="/api/export/memories.json" download="persmem-memories.json">Export JSON</a>
  <a class="export-btn" href="/api/export/memories.md" download="persmem-memories.md">Export Markdown</a>
  <a class="export-btn" href="/api/export/news.json" download="persmem-news.json">Export News JSON</a>
</div>
<div class="search-bar">
  <input type="text" id="searchInput" placeholder="Filter..." oninput="renderPage()">
</div>
<div class="filter-row" id="filterRow"></div>
<div class="memory-list" id="memoryList"></div>
<div class="pagination" id="pagination"></div>

<script>
const MEMORIES = {{ memories_json | safe }};
const NEWS = {{ news_json | safe }};
const COLORS = ['#2d7dd2','#9b59b6','#27ae60','#d4920b','#e74c3c','#3498db','#e67e22','#1abc9c','#95a5a6','#8e44ad'];
const TZ = 'America/Chicago';
const PAGE_SIZE = {{ page_size }};
let currentTab = 'memories';
let currentPage = 0;
let activeFilters = { project: null, type: null };

// --- Donut charts ---
function donut(id, labels, data) {
  new Chart(document.getElementById(id), {
    type: 'doughnut',
    data: {
      labels: labels,
      datasets: [{ data: data, backgroundColor: COLORS.slice(0, labels.length), borderColor: '#f6f8fa', borderWidth: 2 }]
    },
    options: {
      cutout: '60%',
      plugins: { legend: { position: 'bottom', labels: { color: '#656d76', font: { size: 11 }, padding: 10, usePointStyle: true, pointStyleWidth: 8 } } },
      responsive: true, maintainAspectRatio: true
    }
  });
}
const projects = {{ projects_json | safe }};
const types = {{ types_json | safe }};
const tags = {{ tags_json | safe }};
donut('projectChart', Object.keys(projects), Object.values(projects));
donut('typeChart', Object.keys(types), Object.values(types));
donut('tagChart', Object.keys(tags).slice(0,10), Object.values(tags).slice(0,10));

// --- Stacked Activity Timeline ---
const activity = {{ activity_json | safe }};
const actDays = Object.keys(activity);
new Chart(document.getElementById('activityChart'), {
  type: 'bar',
  data: {
    labels: actDays.map(d => d.slice(5)),
    datasets: [
      { label: 'Memories', data: actDays.map(d => activity[d].memories), backgroundColor: '#9b59b6' },
      { label: 'AMQ', data: actDays.map(d => activity[d].amq), backgroundColor: '#2d7dd2' },
      { label: 'News', data: actDays.map(d => activity[d].news), backgroundColor: '#27ae60' },
    ]
  },
  options: {
    responsive: true, maintainAspectRatio: false,
    scales: {
      x: { stacked: true, ticks: { color: '#656d76', font: { size: 10 } }, grid: { display: false } },
      y: { stacked: true, ticks: { color: '#656d76', font: { size: 10 } }, grid: { color: '#eef1f5' } }
    },
    plugins: { legend: { labels: { color: '#656d76', font: { size: 11 }, usePointStyle: true, pointStyleWidth: 8, padding: 12 } } }
  }
});

// --- Mission Control Sparkline (auto-refreshing heartbeat) ---
var sparklineChart = null;
function renderSparkline(actData) {
  var days = Object.keys(actData);
  var config = {
    type: 'line',
    data: {
      labels: days.map(function(d) { return d.slice(5); }),
      datasets: [
        { data: days.map(function(d) { return actData[d].memories; }), borderColor: '#9b59b6', borderWidth: 1.5, pointRadius: 0, tension: 0.2, fill: { target: 'origin', above: 'rgba(155,89,182,0.05)' } },
        { data: days.map(function(d) { return actData[d].amq; }), borderColor: '#2d7dd2', borderWidth: 1.5, pointRadius: 0, tension: 0.2, fill: { target: 'origin', above: 'rgba(45,125,210,0.04)' } },
        { data: days.map(function(d) { return actData[d].news; }), borderColor: '#27ae60', borderWidth: 1, pointRadius: 0, tension: 0.2, fill: false },
      ]
    },
    options: {
      responsive: true, maintainAspectRatio: false,
      scales: { x: { display: false }, y: { display: false, beginAtZero: true } },
      plugins: { legend: { display: false }, tooltip: { enabled: false } },
      interaction: { enabled: false },
      animation: { duration: 800, easing: 'easeOutQuart' }
    }
  };
  if (sparklineChart) { sparklineChart.destroy(); }
  sparklineChart = new Chart(document.getElementById('sparkline'), config);
}
renderSparkline(activity);

async function refreshSparkline() {
  try {
    var r = await fetch('/api/activity?_t='+Date.now(), {cache:'no-store'});
    var data = await r.json();
    renderSparkline(data);
  } catch(e) {}
}
setInterval(refreshSparkline, 30000);

// --- AMQ Feed ---
let lastAmqCount = 0;
let expandedAmq = new Set();

function agentClass(name) {
  if (['kite','wren','knot'].includes(name)) return name;
  return 'news';
}

function formatDate(iso) {
  if (!iso) return '';
  const d = new Date(iso);
  const today = new Date().toLocaleDateString('en-US', {timeZone: TZ});
  const msgDay = d.toLocaleDateString('en-US', {timeZone: TZ});
  const time = d.toLocaleTimeString('en-US', {hour:'2-digit', minute:'2-digit', timeZone: TZ});
  return msgDay === today ? time : d.toLocaleDateString('en-US', {month:'short', day:'numeric', timeZone:TZ}) + ' ' + time;
}

function copyText(el, btn) {
  var card = btn.closest('[data-copy]');
  var text = card ? card.getAttribute('data-copy') : '';
  // Fallback for non-HTTPS (LAN dashboard): hidden textarea + execCommand
  try {
    var ta = document.createElement('textarea');
    ta.value = text;
    ta.style.position = 'fixed';
    ta.style.left = '-9999px';
    document.body.appendChild(ta);
    ta.select();
    document.execCommand('copy');
    document.body.removeChild(ta);
    btn.textContent = 'Copied!'; btn.style.color = '#2ea043';
    setTimeout(function() { btn.textContent = 'Copy'; btn.style.color = ''; }, 1500);
  } catch(e) {
    btn.textContent = 'Failed'; btn.style.color = '#e74c3c';
    setTimeout(function() { btn.textContent = 'Copy'; btn.style.color = ''; }, 1500);
  }
  event.stopPropagation();
}

function toggleAmq(el, id) {
  if (window.getSelection().toString().length > 0) return;
  if (expandedAmq.has(id)) { expandedAmq.delete(id); el.classList.remove('expanded'); }
  else { expandedAmq.add(id); el.classList.add('expanded'); }
}

function renderAmq(messages) {
  const feed = document.getElementById('amqFeed');
  const counts = document.getElementById('amqCounts');
  const status = document.getElementById('amqStatus');
  if (!messages.length) { feed.innerHTML = '<div class="amq-empty">No messages.</div>'; status.textContent = 'No messages'; counts.innerHTML = ''; return; }

  const byAgent = {};
  messages.forEach(m => { byAgent[m.from] = (byAgent[m.from]||0) + 1; });
  const unread = messages.filter(m => m.status === 'unread').length;
  counts.innerHTML = Object.entries(byAgent).map(([a,c]) =>
    '<span class="amq-count-badge ' + agentClass(a) + '">' + a.charAt(0).toUpperCase()+a.slice(1) + ': ' + c + '</span>'
  ).join('') + (unread ? '<span class="amq-count-badge" style="background:rgba(231,76,60,0.1);color:#e74c3c;border:1px solid rgba(231,76,60,0.25);">' + unread + ' unread</span>' : '');
  status.textContent = messages.length + ' messages';

  feed.innerHTML = messages.map(m => {
    const from = m.from||'?', to = m.to||'?', cls = agentClass(from);
    const exp = expandedAmq.has(m.id) ? ' expanded' : '';
    const unr = m.status==='unread' ? ' unread' : '';
    const bodyRaw = (m.body||'').replace(/"/g,'&quot;').replace(/</g,'&lt;');
    const bodyHtml = m.body_html || (m.body||'').replace(/</g,'&lt;').replace(/\n/g,'<br>');
    return '<div class="amq-msg from-'+cls+unr+exp+'" data-copy="'+(m.body||'').replace(/"/g,'&quot;')+'" onclick="toggleAmq(this,\''+m.id+'\')">' +
      '<button class="copy-btn" onclick="copyText(this.parentNode, this)">Copy</button>' +
      '<div class="amq-msg-header">' +
        '<span class="amq-sender '+cls+'">'+from+'</span>' +
        '<span class="amq-arrow">&rarr;</span>' +
        '<span class="amq-recipient">'+to+'</span>' +
        (m.kind ? '<span class="amq-kind">'+m.kind+'</span>' : '') +
        (m.status==='unread' ? '<span class="amq-unread-badge">NEW</span>' : '') +
        '<span class="amq-time">'+formatDate(m.created)+'</span>' +
      '</div>' +
      (m.subject ? '<div class="amq-subject">'+(m.subject||'').replace(/</g,'&lt;')+'</div>' : '') +
      '<div class="amq-body">'+bodyHtml+'</div>' +
    '</div>';
  }).join('');
  if (messages.length > lastAmqCount) feed.scrollTop = 0;
  lastAmqCount = messages.length;
}

async function pollAmq() {
  try {
    const r = await fetch('/api/amq?_t='+Date.now(), {cache:'no-store'});
    renderAmq(await r.json());
  } catch(e) { document.getElementById('amqStatus').textContent = 'Poll failed'; }
}
pollAmq();
setInterval(pollAmq, 5000);

// --- Collection Browser ---
function getData() { return currentTab === 'news' ? NEWS : MEMORIES; }

function switchTab(tab) {
  currentTab = tab; currentPage = 0;
  activeFilters = { project: null, type: null };
  document.getElementById('searchInput').value = '';
  document.querySelectorAll('.tab-btn').forEach((b,i) => b.classList.toggle('active', (i===0&&tab==='memories')||(i===1&&tab==='news')));
  buildFilters(); renderPage();
}

function getFiltered() {
  let data = getData();
  const q = document.getElementById('searchInput').value.toLowerCase();
  if (activeFilters.project) data = data.filter(m => m.project === activeFilters.project);
  if (activeFilters.type) data = data.filter(m => m.type === activeFilters.type);
  if (q) data = data.filter(m => (m.content||'').toLowerCase().includes(q) || (m.tags||'').toLowerCase().includes(q));
  return data;
}

function buildFilters() {
  const row = document.getElementById('filterRow'); row.innerHTML = '';
  const data = getData();
  const allP = [...new Set(data.map(m => m.project).filter(Boolean))];
  const allT = [...new Set(data.map(m => m.type).filter(Boolean))];
  allP.forEach(p => {
    const b = document.createElement('button'); b.className = 'filter-btn'+(activeFilters.project===p?' active':'');
    b.textContent = p; b.onclick = () => { activeFilters.project = activeFilters.project===p?null:p; currentPage=0; buildFilters(); renderPage(); };
    row.appendChild(b);
  });
  allT.forEach(t => {
    const b = document.createElement('button'); b.className = 'filter-btn'+(activeFilters.type===t?' active':'');
    b.textContent = t; b.onclick = () => { activeFilters.type = activeFilters.type===t?null:t; currentPage=0; buildFilters(); renderPage(); };
    row.appendChild(b);
  });
}

function renderPage() {
  const filtered = getFiltered();
  const totalPages = Math.ceil(filtered.length / PAGE_SIZE);
  if (currentPage >= totalPages) currentPage = Math.max(0, totalPages - 1);
  const start = currentPage * PAGE_SIZE;
  const page = filtered.slice(start, start + PAGE_SIZE);
  const list = document.getElementById('memoryList');

  if (!page.length) { list.innerHTML = '<div class="empty-state">No items match filters.</div>'; document.getElementById('pagination').innerHTML=''; return; }

  list.innerHTML = page.map(m => {
    const date = m.stored_at ? new Date(m.stored_at).toLocaleString('en-US', {timeZone:TZ}) : '';
    const tagBadges = (m.tags||'').split(',').filter(Boolean).map(t => '<span class="badge badge-tag">'+t.trim()+'</span>').join('');
    const preview = (m.content||'').length > 120 ? (m.content||'').slice(0,120).replace(/</g,'&lt;')+'...' : (m.content||'').replace(/</g,'&lt;');
    const contentHtml = m.content_html || (m.content||'').replace(/</g,'&lt;').replace(/\n/g,'<br>');
    const rawContent = (m.content||'').replace(/"/g,'&quot;');
    return '<div class="memory-card" data-copy="'+rawContent+'" onclick="if(window.getSelection().toString().length>0)return;this.classList.toggle(\'expanded\')">' +
      '<button class="copy-btn" onclick="copyText(this.parentNode, this)">Copy</button>' +
      '<div class="memory-meta">' +
        '<span class="badge badge-project">'+(m.project||'general')+'</span>' +
        '<span class="badge badge-type">'+(m.type||'note')+'</span>' +
        tagBadges +
        '<span class="memory-date">'+date+'</span>' +
      '</div>' +
      '<div class="memory-preview">'+preview+'</div>' +
      '<div class="memory-content">'+contentHtml+'</div>' +
      '<div class="memory-id">'+(m.id||'')+'</div>' +
    '</div>';
  }).join('');

  const pag = document.getElementById('pagination');
  if (totalPages <= 1) { pag.innerHTML = ''; return; }
  pag.innerHTML =
    '<button onclick="currentPage=0;renderPage()" '+(currentPage===0?'disabled':'')+'>&#171;</button>' +
    '<button onclick="currentPage--;renderPage()" '+(currentPage===0?'disabled':'')+'>&#8249; Prev</button>' +
    '<span class="page-info">'+(currentPage+1)+' / '+totalPages+' ('+filtered.length+' items)</span>' +
    '<button onclick="currentPage++;renderPage()" '+(currentPage>=totalPages-1?'disabled':'')+'>Next &#8250;</button>' +
    '<button onclick="currentPage='+String(totalPages-1)+';renderPage()" '+(currentPage>=totalPages-1?'disabled':'')+'>&#187;</button>';
}

// --- AMQ Compose ---
async function sendAmq() {
  const btn = document.getElementById('composeSend');
  const fb = document.getElementById('composeFeedback');
  const from = document.getElementById('composeFrom').value;
  const to = document.getElementById('composeTo').value;
  const subject = document.getElementById('composeSubject').value.trim();
  const body = document.getElementById('composeBody').value.trim();
  if (!body) { fb.textContent = 'Body is required'; fb.className = 'compose-feedback err'; return; }
  btn.disabled = true; fb.textContent = 'Sending...'; fb.className = 'compose-feedback';
  try {
    const r = await fetch('/api/amq/send', {
      method: 'POST', headers: {'Content-Type':'application/json'},
      body: JSON.stringify({from: from, to: to, subject: subject, body: body})
    });
    const data = await r.json();
    if (data.ok) {
      fb.textContent = 'Sent to ' + to + ' \u2713'; fb.className = 'compose-feedback ok';
      document.getElementById('composeBody').value = '';
      document.getElementById('composeSubject').value = '';
      pollAmq();
    } else {
      fb.textContent = data.error || 'Send failed'; fb.className = 'compose-feedback err';
    }
  } catch(e) { fb.textContent = e.message; fb.className = 'compose-feedback err'; }
  btn.disabled = false;
}

// --- System Status Polling ---
async function pollStatus() {
  try {
    const r = await fetch('/api/system?_t='+Date.now(), {cache:'no-store'});
    const d = await r.json();
    document.getElementById('statusUptime').textContent = 'Uptime: ' + d.uptime;
    document.getElementById('statusModel').textContent = d.model;
    document.getElementById('dotPersmem').className = 'status-dot ' + (d.persmem_ok ? 'green' : 'red');
  } catch(e) {
    document.getElementById('dotPersmem').className = 'status-dot red';
  }
}
pollStatus();
setInterval(pollStatus, 30000);

buildFilters();
renderPage();
</script>
</body>
</html>
"""


def safe_json(data):
    """JSON-encode for safe embedding inside HTML <script> tags.
    Escapes </ sequences that would prematurely close script blocks."""
    return json.dumps(data, default=str).replace("</", r"<\/")


# ============================
# Routes
# ============================

def no_cache(resp):
    resp.headers['Cache-Control'] = 'no-cache, no-store, must-revalidate'
    resp.headers['Pragma'] = 'no-cache'
    resp.headers['Expires'] = '0'
    return resp


@app.route("/")
def dashboard():
    memories = get_all_from_collection("memories")
    news_items = get_all_from_collection("news")
    amq_messages = get_amq_messages()
    agents = discover_agents()

    total_memories = len(memories)
    total_news = len(news_items)
    total_amq = len(amq_messages)

    projects = Counter(m.get("project", "general") for m in memories)
    types = Counter(m.get("type", "note") for m in memories)

    all_tags = []
    for m in memories:
        all_tags.extend(t.strip() for t in m.get("tags", "").split(",") if t.strip())
    tag_counts = Counter(all_tags)
    unique_tags = len(tag_counts)

    # Render markdown for memories and news
    memories_sorted = sorted(memories, key=lambda m: m.get("stored_at", ""), reverse=True)
    for m in memories_sorted:
        m["content_html"] = mini_markdown(m.get("content", ""))

    news_sorted = sorted(news_items, key=lambda n: n.get("stored_at", ""), reverse=True)
    for n in news_sorted:
        # News items contain raw HTML from RSS feeds — strip to clean text, then render
        cleaned = strip_html(n.get("content", ""))
        n["content_html"] = mini_markdown(cleaned)
        n["content"] = cleaned  # Also clean the raw content for preview/copy

    activity = get_activity_data(memories, news_items, amq_messages)

    resp = make_response(render_template_string(
        DASHBOARD_HTML,
        total_memories=total_memories,
        total_news=total_news,
        total_amq=total_amq,
        projects=projects,
        types=types,
        unique_tags=unique_tags,
        agents=agents,
        page_size=PAGE_SIZE,
        projects_json=safe_json(dict(projects)),
        types_json=safe_json(dict(types)),
        tags_json=safe_json(dict(tag_counts.most_common(10))),
        activity_json=safe_json(activity),
        memories_json=safe_json(memories_sorted),
        news_json=safe_json(news_sorted),
    ))
    return no_cache(resp)


@app.route("/api/memories")
def api_memories():
    return jsonify(get_all_from_collection("memories"))


@app.route("/api/news")
def api_news():
    return jsonify(get_all_from_collection("news"))


@app.route("/api/stats")
def api_stats():
    memories = get_all_from_collection("memories")
    projects = Counter(m.get("project", "general") for m in memories)
    types = Counter(m.get("type", "note") for m in memories)
    collections = list_collections()
    return jsonify({
        "total": len(memories),
        "projects": dict(projects),
        "types": dict(types),
        "collections": [{"name": n, "count": c} for n, c in collections],
    })


@app.route("/api/amq")
def api_amq():
    data = get_amq_messages()
    return no_cache(make_response(jsonify(data)))


@app.route("/api/amq/send", methods=["POST"])
def api_amq_send():
    """Send an AMQ message from the dashboard (Holden → agent)."""
    try:
        data = request.get_json()
        from_agent = data.get("from", "holden")
        to_agent = data.get("to", "")
        subject = data.get("subject", "")
        body = data.get("body", "")

        if not to_agent or not body:
            return jsonify({"ok": False, "error": "to and body required"})

        # Build message in AMQ Maildir format
        now = datetime.now(timezone.utc)
        ts = now.strftime("%Y%m%dT%H%M%S")
        us = f"{now.microsecond:06d}"
        short_id = uuid.uuid4().hex[:8]
        msg_id = f"{ts}-{us}_{from_agent}_{short_id}"

        headers = {
            "schema": 1,
            "id": msg_id,
            "from": from_agent,
            "to": to_agent,
            "subject": subject,
            "kind": "message",
            "priority": "normal",
            "created": now.isoformat(),
        }

        content = f"---json\n{json.dumps(headers, indent=2)}\n---\n{body}\n"

        # Write to recipient's inbox/new/ (Maildir atomic: write to tmp, move to new)
        inbox_new = os.path.join(AMQ_ROOT, to_agent, "inbox", "new")
        inbox_tmp = os.path.join(AMQ_ROOT, to_agent, "inbox", "tmp")
        os.makedirs(inbox_new, exist_ok=True)
        os.makedirs(inbox_tmp, exist_ok=True)

        fname = f"{msg_id}.md"
        tmp_path = os.path.join(inbox_tmp, fname)
        new_path = os.path.join(inbox_new, fname)

        with open(tmp_path, "w") as f:
            f.write(content)
        os.rename(tmp_path, new_path)

        return jsonify({"ok": True, "id": msg_id, "to": to_agent})
    except Exception as e:
        return jsonify({"ok": False, "error": str(e)})


@app.route("/api/system")
def api_system():
    """System status for the status bar."""
    try:
        # Uptime
        with open("/proc/uptime") as f:
            up_secs = float(f.read().split()[0])
        days = int(up_secs // 86400)
        hours = int((up_secs % 86400) // 3600)
        mins = int((up_secs % 3600) // 60)
        if days > 0:
            uptime_str = f"{days}d {hours}h {mins}m"
        elif hours > 0:
            uptime_str = f"{hours}h {mins}m"
        else:
            uptime_str = f"{mins}m"

        # Collection counts
        collections = list_collections()
        col_dict = {n: c for n, c in collections}
        memories = col_dict.get("memories", 0)
        news = col_dict.get("news", 0)

        # AMQ count
        amq_count = 0
        for agent in discover_agents():
            for subdir in ["new", "cur"]:
                dirpath = os.path.join(AMQ_ROOT, agent, "inbox", subdir)
                try:
                    amq_count += len([f for f in os.listdir(dirpath) if f.endswith(".md")])
                except OSError:
                    pass

        # Model name — read from server.py default since env var isn't in dashboard scope
        model_name = "unknown"
        try:
            with open("/opt/persmem/server.py", "r") as f:
                for line in f:
                    if "PERSMEM_EMBEDDING_MODEL" in line and "os.environ" in line:
                        # Extract default path from: os.environ.get("PERSMEM_EMBEDDING_MODEL", "/opt/persmem/models/voyage-4-nano")
                        parts = line.split('"')
                        for i, p in enumerate(parts):
                            if "/opt/persmem/models/" in p:
                                model_name = os.path.basename(p)
                                break
                        break
        except OSError:
            pass

        # persMEM service check (quick)
        persmem_ok = True  # if dashboard can read chromadb, persmem infra is up

        return no_cache(make_response(jsonify({
            "uptime": uptime_str,
            "memories": memories,
            "news": news,
            "amq": amq_count,
            "model": model_name,
            "persmem_ok": persmem_ok,
        })))
    except Exception as e:
        return jsonify({"uptime": "error", "persmem_ok": False, "error": str(e)})


@app.route("/api/export/memories.json")
def api_export_memories_json():
    """Download all memories as JSON."""
    memories = get_all_from_collection("memories")
    resp = make_response(json.dumps(memories, indent=2, default=str))
    resp.headers["Content-Type"] = "application/json"
    resp.headers["Content-Disposition"] = "attachment; filename=persmem-memories.json"
    return resp


@app.route("/api/export/memories.md")
def api_export_memories_md():
    """Download all memories as Markdown."""
    memories = get_all_from_collection("memories")
    memories_sorted = sorted(memories, key=lambda m: m.get("stored_at", ""), reverse=True)
    lines = [f"# persMEM Memory Export\n\nExported: {datetime.now(timezone.utc).isoformat()}\n\nTotal: {len(memories_sorted)} memories\n\n---\n"]
    for m in memories_sorted:
        project = m.get("project", "general")
        mtype = m.get("type", "note")
        tags = m.get("tags", "")
        stored = m.get("stored_at", "")
        mid = m.get("id", "")
        lines.append(f"## [{project}] {mtype} — {stored[:10]}\n")
        if tags:
            lines.append(f"**Tags:** {tags}\n")
        lines.append(f"**ID:** `{mid}`\n\n")
        lines.append(m.get("content", "") + "\n\n---\n\n")
    resp = make_response("".join(lines))
    resp.headers["Content-Type"] = "text/markdown; charset=utf-8"
    resp.headers["Content-Disposition"] = "attachment; filename=persmem-memories.md"
    return resp


@app.route("/api/export/news.json")
def api_export_news_json():
    """Download all news items as JSON."""
    news = get_all_from_collection("news")
    resp = make_response(json.dumps(news, indent=2, default=str))
    resp.headers["Content-Type"] = "application/json"
    resp.headers["Content-Disposition"] = "attachment; filename=persmem-news.json"
    return resp


@app.route("/api/activity")
def api_activity():
    """Fresh activity data for sparkline auto-refresh."""
    memories = get_all_from_collection("memories")
    news_items = get_all_from_collection("news")
    amq_messages = get_amq_messages()
    activity = get_activity_data(memories, news_items, amq_messages)
    return no_cache(make_response(jsonify(activity)))


